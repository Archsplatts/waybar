{
	"include": ["$HOME/.config/mango/waybar/modules/*.jsonc"],

	"layer": "top",
	"position": "bottom",
	"height": 32,
	"spacing": 0,
	"reload_style_on_change": true,
	
	"modules-left": ["custom/menu","tray","custom/updates","wlr/taskbar","custom/arrow10"],

	"modules-center": ["ext/workspaces"],
	
	"modules-right": ["custom/arrow5","pulseaudio","custom/arrow4","network","custom/arrow3","disk#ssd",
	"custom/arrow2","custom/kernel","custom/arrow1","clock"],
}
